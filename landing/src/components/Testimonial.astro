---
interface Social {
	platform: 'linkedin' | 'x';
	url: string;
}

interface Props {
	quote: string;
	name: string;
	role: string;
	photo: string;
	socials: Social[];
}

const { quote, name, role, photo, socials } = Astro.props;
---

<div class="bg-bg border border-border px-5 py-5">
	<blockquote class="text-base text-text-secondary leading-relaxed mb-4 border-l-2 border-accent/30 pl-4 italic">
		"{quote}"
	</blockquote>
	<div class="flex items-center gap-3">
		<img src={photo} alt={name} class="w-10 h-10 rounded-full shrink-0 object-cover" width="40" height="40" loading="lazy" />
		<div>
			<p class="text-sm font-medium text-text">{name}</p>
			<p class="text-xs text-text-muted">{role}</p>
		</div>
		<div class="flex items-center gap-2">
			{socials.map((s) => (
				<a href={s.url} target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors" aria-label={`${name} on ${s.platform === 'linkedin' ? 'LinkedIn' : 'X'}`}>
					{s.platform === 'linkedin' ? (
						<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
					) : (
						<svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
					)}
				</a>
			))}
		</div>
	</div>
</div>
