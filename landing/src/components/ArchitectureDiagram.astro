---
// Animated architecture diagram for the landing page.
// Left = inputs to the agent (modules + secrets), Right = integrations the agent calls out to.
---

<div class="arch-wrap" role="img" aria-label="Architecture diagram: context modules (linear, supabase) and secrets via Infisical flow into an agent workspace, which calls out to integrations like Linear and Supabase in real time">
  <svg viewBox="0 0 700 340" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">

    <!-- ─── Filters ─── -->
    <defs>
      <filter id="ad-glow" x="-60%" y="-60%" width="220%" height="220%">
        <feGaussianBlur stdDeviation="3.5" result="b"/>
        <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
      </filter>
      <radialGradient id="ad-center" cx="50%" cy="50%" r="50%">
        <stop offset="0%"   stop-color="#c4a35a" stop-opacity="0.07"/>
        <stop offset="100%" stop-color="#c4a35a" stop-opacity="0"/>
      </radialGradient>
    </defs>

    <!-- ─── Background ─── -->
    <rect width="700" height="340" fill="#1c1c1a" rx="8"/>
    <ellipse cx="365" cy="170" rx="170" ry="140" fill="url(#ad-center)"/>

    <!-- ══════════════════════════════════════════
         LEFT PANEL — Modules + Secrets (inputs)
    ══════════════════════════════════════════ -->

    <text x="88" y="46" text-anchor="middle"
          font-family="Inter, ui-sans-serif, sans-serif"
          font-size="8.5" font-weight="500" fill="#5a5856" letter-spacing="1.8">MODULES</text>

    <!-- linear (active) -->
    <rect x="18" y="54" width="140" height="32" rx="3" fill="#252523" stroke="#c4a35a" stroke-width="1"/>
    <circle cx="34" cy="70" r="3.5" fill="#c4a35a" filter="url(#ad-glow)">
      <animate attributeName="opacity" values="1;0.25;1" dur="4s" repeatCount="indefinite"/>
    </circle>
    <text x="46" y="75" font-family="'SF Mono','Fira Code','Courier New',monospace" font-size="11" fill="#c4a35a">linear</text>
    <text x="151" y="75" text-anchor="end" font-family="Inter, sans-serif" font-size="7.5" fill="#5a5856">loaded</text>

    <!-- supabase (active) -->
    <rect x="18" y="93" width="140" height="32" rx="3" fill="#252523" stroke="#c4a35a" stroke-width="1"/>
    <circle cx="34" cy="109" r="3.5" fill="#c4a35a" filter="url(#ad-glow)">
      <animate attributeName="opacity" values="1;0.25;1" dur="4s" begin="0.8s" repeatCount="indefinite"/>
    </circle>
    <text x="46" y="114" font-family="'SF Mono','Fira Code','Courier New',monospace" font-size="11" fill="#c4a35a">supabase</text>
    <text x="151" y="114" text-anchor="end" font-family="Inter, sans-serif" font-size="7.5" fill="#5a5856">loaded</text>

    <!-- jira (not loaded) -->
    <rect x="18" y="132" width="140" height="32" rx="3" fill="#252523" stroke="#403e3a" stroke-width="1"/>
    <circle cx="34" cy="148" r="3.5" fill="#2e2d2b"/>
    <text x="46" y="153" font-family="'SF Mono','Fira Code','Courier New',monospace" font-size="11" fill="#5a5856">jira</text>

    <!-- notion (not loaded) -->
    <rect x="18" y="171" width="140" height="32" rx="3" fill="#252523" stroke="#403e3a" stroke-width="1"/>
    <circle cx="34" cy="187" r="3.5" fill="#2e2d2b"/>
    <text x="46" y="192" font-family="'SF Mono','Fira Code','Courier New',monospace" font-size="11" fill="#5a5856">notion</text>

    <text x="88" y="220" text-anchor="middle" font-family="Inter, sans-serif" font-size="9" fill="#403e3a">+ 12 more</text>

    <line x1="18" y1="233" x2="158" y2="233" stroke="#403e3a" stroke-width="0.5" opacity="0.6"/>

    <text x="88" y="249" text-anchor="middle"
          font-family="Inter, ui-sans-serif, sans-serif"
          font-size="8.5" font-weight="500" fill="#5a5856" letter-spacing="1.8">SECRETS</text>

    <!-- Infisical (active) -->
    <rect x="18" y="257" width="140" height="36" rx="3" fill="#252523" stroke="#c4a35a" stroke-width="1"/>
    <circle cx="34" cy="275" r="3.5" fill="#c4a35a" filter="url(#ad-glow)">
      <animate attributeName="opacity" values="1;0.25;1" dur="4s" begin="1.6s" repeatCount="indefinite"/>
    </circle>
    <text x="46" y="272" font-family="Inter, sans-serif" font-size="10" font-weight="500" fill="#c4a35a">Infisical</text>
    <text x="46" y="285" font-family="Inter, sans-serif" font-size="7.5" fill="#5a5856">runtime secrets via Varlock</text>

    <!-- ══════════════════════════════════════════
         CONNECTIONS — inputs → workspace
    ══════════════════════════════════════════ -->
    <path d="M 158 70 C 220 70 235 163 270 163"
          stroke="#403e3a" stroke-width="1" fill="none" stroke-dasharray="4 3" opacity="0.9"/>
    <path d="M 158 109 C 220 109 235 167 270 167"
          stroke="#403e3a" stroke-width="1" fill="none" stroke-dasharray="4 3" opacity="0.9"/>
    <path d="M 158 275 C 222 275 238 212 270 212"
          stroke="#403e3a" stroke-width="1" fill="none" stroke-dasharray="4 3" opacity="0.9"/>

    <!-- linear → workspace (2 dots) -->
    <circle r="2.8" fill="#c4a35a" filter="url(#ad-glow)">
      <animateMotion dur="3s" repeatCount="indefinite" begin="0s"
        path="M 158 70 C 220 70 235 163 270 163"/>
      <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.15;0.8;1"
               dur="3s" repeatCount="indefinite" begin="0s"/>
    </circle>
    <circle r="2.8" fill="#c4a35a" filter="url(#ad-glow)">
      <animateMotion dur="3s" repeatCount="indefinite" begin="1.5s"
        path="M 158 70 C 220 70 235 163 270 163"/>
      <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.15;0.8;1"
               dur="3s" repeatCount="indefinite" begin="1.5s"/>
    </circle>

    <!-- supabase → workspace (2 dots) -->
    <circle r="2.8" fill="#c4a35a" filter="url(#ad-glow)">
      <animateMotion dur="3s" repeatCount="indefinite" begin="0.5s"
        path="M 158 109 C 220 109 235 167 270 167"/>
      <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.15;0.8;1"
               dur="3s" repeatCount="indefinite" begin="0.5s"/>
    </circle>
    <circle r="2.8" fill="#c4a35a" filter="url(#ad-glow)">
      <animateMotion dur="3s" repeatCount="indefinite" begin="2s"
        path="M 158 109 C 220 109 235 167 270 167"/>
      <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.15;0.8;1"
               dur="3s" repeatCount="indefinite" begin="2s"/>
    </circle>

    <!-- secrets → workspace (1 dot) -->
    <circle r="2.5" fill="#c4a35a" filter="url(#ad-glow)">
      <animateMotion dur="3.8s" repeatCount="indefinite" begin="0.7s"
        path="M 158 275 C 222 275 238 212 270 212"/>
      <animate attributeName="opacity" values="0;0.8;0.8;0" keyTimes="0;0.15;0.8;1"
               dur="3.8s" repeatCount="indefinite" begin="0.7s"/>
    </circle>

    <!-- ══════════════════════════════════════════
         CENTER — Agent Workspace
    ══════════════════════════════════════════ -->
    <rect x="268" y="46" width="196" height="262" rx="7"
          fill="none" stroke="#c4a35a" stroke-width="1.5" opacity="0.45"/>
    <rect x="270" y="48" width="192" height="258" rx="6" fill="#252523"/>

    <rect x="270" y="48" width="192" height="24" rx="6" fill="#2e2d2b"/>
    <rect x="270" y="60" width="192" height="12" fill="#2e2d2b"/>
    <circle cx="285" cy="60" r="3.5" fill="#403e3a"/>
    <circle cx="298" cy="60" r="3.5" fill="#403e3a"/>
    <circle cx="311" cy="60" r="3.5" fill="#403e3a"/>
    <text x="366" y="65" text-anchor="middle"
          font-family="Inter, sans-serif" font-size="8.5" fill="#908e8c">agent workspace</text>

    <text x="286" y="92"  font-family="'SF Mono',monospace" font-size="9.5" fill="#5a5856">$ context load</text>
    <text x="286" y="109" font-family="'SF Mono',monospace" font-size="9.5" fill="#c4a35a">&#x2714; 2 modules + secrets loaded</text>

    <line x1="286" y1="121" x2="446" y2="121" stroke="#403e3a" stroke-width="0.5"/>

    <text x="286" y="137" font-family="'SF Mono',monospace" font-size="9" fill="#908e8c">context/</text>
    <text x="286" y="153" font-family="'SF Mono',monospace" font-size="9" fill="#d8d6d4">&#x251C;&#x2500;&#x2500; linear/</text>
    <text x="286" y="168" font-family="'SF Mono',monospace" font-size="9" fill="#d8d6d4">&#x2514;&#x2500;&#x2500; supabase/</text>

    <line x1="286" y1="180" x2="446" y2="180" stroke="#403e3a" stroke-width="0.5"/>

    <rect x="282" y="187" width="176" height="20" rx="3" fill="#1c1c1a"/>
    <text x="370" y="201" text-anchor="middle"
          font-family="Inter, sans-serif" font-size="8" fill="#908e8c">
      agent only sees what's loaded
    </text>

    <rect x="282" y="217" width="176" height="38" rx="4" fill="#2e2d2b"/>
    <text x="294" y="241" font-family="Inter, sans-serif" font-size="10" font-weight="500" fill="#d8d6d4">Chat interface</text>
    <rect x="372" y="231" width="5" height="9" rx="1" fill="#c4a35a">
      <animate attributeName="opacity" values="0.9;0;0.9" dur="1.8s" repeatCount="indefinite"/>
    </rect>

    <text x="366" y="292" text-anchor="middle"
          font-family="Inter, sans-serif" font-size="8" fill="#5a5856">
      Anthropic &#xB7; OpenAI &#xB7; Ollama
    </text>

    <!-- ══════════════════════════════════════════
         RIGHT PANEL — Integrations
    ══════════════════════════════════════════ -->
    <text x="605" y="46" text-anchor="middle"
          font-family="Inter, ui-sans-serif, sans-serif"
          font-size="8.5" font-weight="500" fill="#5a5856" letter-spacing="1.8">INTEGRATIONS</text>

    <rect x="528" y="108" width="154" height="44" rx="3" fill="#252523" stroke="#403e3a" stroke-width="1"/>
    <text x="544" y="128" font-family="Inter, sans-serif" font-size="10.5" font-weight="500" fill="#d8d6d4">Linear</text>
    <text x="544" y="143" font-family="Inter, sans-serif" font-size="8" fill="#5a5856">Issues &#xB7; Projects &#xB7; Cycles</text>

    <rect x="528" y="210" width="154" height="44" rx="3" fill="#252523" stroke="#403e3a" stroke-width="1"/>
    <text x="544" y="230" font-family="Inter, sans-serif" font-size="10.5" font-weight="500" fill="#d8d6d4">Supabase</text>
    <text x="544" y="244" font-family="Inter, sans-serif" font-size="8" fill="#5a5856">Database &#xB7; Auth &#xB7; Storage</text>

    <text x="605" y="284" text-anchor="middle" font-family="Inter, sans-serif" font-size="9" fill="#403e3a">+ any API</text>

    <!-- ══════════════════════════════════════════
         CONNECTIONS — bidirectional live traffic
    ══════════════════════════════════════════ -->

    <!-- Guide lines -->
    <path d="M 462 146 C 496 146 496 128 528 128"
          stroke="#403e3a" stroke-width="0.7" fill="none" opacity="0.45"/>
    <path d="M 528 133 C 496 133 496 151 462 151"
          stroke="#403e3a" stroke-width="0.7" fill="none" opacity="0.3"/>
    <path d="M 462 206 C 496 206 496 230 528 230"
          stroke="#403e3a" stroke-width="0.7" fill="none" opacity="0.45"/>
    <path d="M 528 235 C 496 235 496 211 462 211"
          stroke="#403e3a" stroke-width="0.7" fill="none" opacity="0.3"/>

    <!-- LINEAR outgoing — 1 gold dot -->
    <circle r="2.5" fill="#c4a35a" filter="url(#ad-glow)">
      <animateMotion dur="2.5s" repeatCount="indefinite" begin="0s"
        path="M 462 146 C 496 146 496 128 528 128"/>
      <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.1;0.88;1"
               dur="2.5s" repeatCount="indefinite" begin="0s"/>
    </circle>

    <!-- LINEAR incoming — 1 gray dot -->
    <circle r="1.8" fill="#908e8c">
      <animateMotion dur="2s" repeatCount="indefinite" begin="0.8s"
        path="M 528 133 C 496 133 496 151 462 151"/>
      <animate attributeName="opacity" values="0;0.75;0.75;0" keyTimes="0;0.12;0.86;1"
               dur="2s" repeatCount="indefinite" begin="0.8s"/>
    </circle>

    <!-- SUPABASE outgoing — 1 gold dot, offset from Linear -->
    <circle r="2.5" fill="#c4a35a" filter="url(#ad-glow)">
      <animateMotion dur="2.5s" repeatCount="indefinite" begin="1.2s"
        path="M 462 206 C 496 206 496 230 528 230"/>
      <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.1;0.88;1"
               dur="2.5s" repeatCount="indefinite" begin="1.2s"/>
    </circle>

    <!-- SUPABASE incoming — 1 gray dot -->
    <circle r="1.8" fill="#908e8c">
      <animateMotion dur="2s" repeatCount="indefinite" begin="2.0s"
        path="M 528 235 C 496 235 496 211 462 211"/>
      <animate attributeName="opacity" values="0;0.75;0.75;0" keyTimes="0;0.12;0.86;1"
               dur="2s" repeatCount="indefinite" begin="2.0s"/>
    </circle>

  </svg>
</div>

<style>
  .arch-wrap {
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .arch-wrap svg {
    display: block;
    width: 100%;
    height: auto;
    min-width: 480px;
  }
</style>
