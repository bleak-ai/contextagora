---
import Base from '../layouts/Base.astro';
---

<Base title="ContextAgora: The AI support layer for startups">

	<!-- Hero -->
	<section class="mb-16 sm:mb-24 text-center pt-8 sm:pt-16">
		<h1 class="text-5xl sm:text-7xl font-semibold text-accent tracking-tight mb-4 leading-none">
			ContextAgora
		</h1>
		<p class="text-lg sm:text-xl text-text font-medium mb-6">The AI support layer built for startups</p>
		<p class="text-base text-text-secondary leading-relaxed max-w-sm mx-auto">
			Let your AI agents handle support, ops, and integrations without babysitting every prompt.
		</p>
	</section>

	<!-- Waitlist -->
	<section class="mb-16 sm:mb-24">
		<div class="border border-accent/20 bg-bg-raised px-6 py-8 sm:px-8 max-w-lg mx-auto">
			<p class="text-xs font-medium text-accent uppercase tracking-widest mb-3">Early access</p>
			<h2 class="text-lg font-medium text-text mb-1">Built for startups moving fast.</h2>
			<p class="text-sm text-text-secondary mb-6">We're opening up to a small group of early-stage teams first. Join the waitlist and we'll be in touch.</p>
			<form id="waitlist-form" class="flex gap-2">
				<input
					type="email"
					name="email"
					required
					placeholder="your@email.com"
					class="flex-1 bg-bg border border-border text-text text-sm px-3 py-2 outline-none focus:border-accent/50 placeholder:text-text-muted transition-colors"
				/>
				<button
					type="submit"
					id="waitlist-btn"
					class="bg-accent text-bg text-sm font-medium px-4 py-2 hover:bg-accent-hover transition-colors cursor-pointer whitespace-nowrap disabled:opacity-50 disabled:cursor-not-allowed"
				>
					Get early access
				</button>
			</form>
			<p id="waitlist-success" class="hidden text-sm text-text-secondary mt-3">You're on the list. We'll be in touch.</p>
		</div>
	</section>

	<script>
		const LOOPS_FORM_ID = 'cmnwwvqz704ex0i1e6ahjp465';

		const form = document.getElementById('waitlist-form') as HTMLFormElement;
		const btn = document.getElementById('waitlist-btn') as HTMLButtonElement;
		const success = document.getElementById('waitlist-success') as HTMLParagraphElement;

		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			btn.disabled = true;
			btn.textContent = 'Joining...';
			const email = (form.elements.namedItem('email') as HTMLInputElement).value;

			try {
				await fetch(`https://app.loops.so/api/newsletter-form/${LOOPS_FORM_ID}`, {
					method: 'POST',
					headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
					body: new URLSearchParams({ email }),
				});
			} catch {}

			form.classList.add('hidden');
			success.classList.remove('hidden');
		});
	</script>

	<!-- How it works -->
	<section class="mb-16 sm:mb-24">
		<h2 class="text-xs font-medium text-text-muted uppercase tracking-widest mb-10">How it works</h2>
		<dl class="space-y-10">
			<div class="flex gap-5">
				<svg class="w-6 h-6 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9.776c.112-.017.227-.026.344-.026h15.812c.117 0 .232.009.344.026m-16.5 0a2.25 2.25 0 0 0-1.883 2.542l.857 6a2.25 2.25 0 0 0 2.227 1.932H19.05a2.25 2.25 0 0 0 2.227-1.932l.857-6a2.25 2.25 0 0 0-1.883-2.542m-16.5 0V6A2.25 2.25 0 0 1 6 3.75h3.879a1.5 1.5 0 0 1 1.06.44l2.122 2.12a1.5 1.5 0 0 0 1.06.44H18A2.25 2.25 0 0 1 20.25 9v.776" /></svg>
				<div>
					<dt class="text-lg font-semibold text-text mb-1">Direct AI access to all 3rd party tools</dt>
					<dd class="text-sm text-text-secondary leading-relaxed">Add any integration as a module. Your AI agent reads what it needs and acts on it, no custom wiring required.</dd>
				</div>
			</div>
			<div class="flex gap-5">
				<svg class="w-6 h-6 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" /></svg>
				<div>
					<dt class="text-lg font-semibold text-text mb-1">Safe secrets with Infisical and Varlock</dt>
					<dd class="text-sm text-text-secondary leading-relaxed">API keys are resolved at runtime and discarded when the task ends. Never stored, never visible.</dd>
				</div>
			</div>
			<div class="flex gap-5">
				<svg class="w-6 h-6 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m21 7.5-9-5.25L3 7.5m18 0-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" /></svg>
				<div>
					<dt class="text-lg font-semibold text-text mb-1">Up in 30 minutes</dt>
					<dd class="text-sm text-text-secondary leading-relaxed">
						<ol class="list-none space-y-1">
							<li>1. Create a private GitHub repo, this is where your context modules live.</li>
							<li>2. Set up an Infisical project to store your API keys and credentials securely.</li>
							<li>3. Deploy with Docker. That's it.</li>
						</ol>
					</dd>
				</div>
			</div>
			<div class="flex gap-5">
				<svg class="w-6 h-6 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" /></svg>
				<div>
					<dt class="text-lg font-semibold text-text mb-1">Context is the base of AI</dt>
					<dd class="text-sm text-text-secondary leading-relaxed">Modules are the foundation. Every agent action is grounded in the context you've loaded, your docs, your tools, your data.</dd>
				</div>
			</div>
		</dl>
	</section>

	<!-- In the wild -->
	<section class="mb-16 sm:mb-24">
		<h2 class="text-xs font-medium text-text-muted uppercase tracking-widest mb-10">Testimonials</h2>

		<!-- Testimonial quotes -->
		<div class="flex flex-col gap-3 mb-8">
			<div class="border border-border bg-bg-raised px-6 py-8 sm:px-8">
				<a href="https://soundmurai.com" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-4 mb-6 w-fit hover:opacity-80 transition-opacity">
					<img src="https://soundmurai.com/favicon.svg" alt="Soundmurai logo" class="w-14 h-14 shrink-0" />
					<span class="text-3xl sm:text-4xl font-bold text-text tracking-tight">Soundmurai</span>
					<svg class="w-4 h-4 text-text-muted -mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
				</a>
				<p class="text-sm text-text-muted uppercase tracking-widest mb-3">Live music marketplace</p>
				<p class="text-lg text-text-secondary leading-relaxed">
					"ContextAgora lets our AI answer real questions about our marketplace — live, from our own database. No custom APIs, no manual queries."
				</p>
			</div>
			<div class="border border-border bg-bg-raised px-6 py-8 sm:px-8">
				<a href="https://maatapp.com" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-4 mb-6 w-fit hover:opacity-80 transition-opacity">
					<img src="https://www.datocms-assets.com/166339/1754751403-logo.svg" alt="MAAT logo" class="w-14 h-14 shrink-0" />
					<span class="text-3xl sm:text-4xl font-bold text-text tracking-tight">MAAT</span>
					<svg class="w-4 h-4 text-text-muted -mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
				</a>
				<p class="text-sm text-text-muted uppercase tracking-widest mb-3">Gym management software for BJJ, MMA & martial arts</p>
				<p class="text-lg text-text-secondary leading-relaxed">
					"We went from spending hours digging through member data to having our AI surface exactly what we need in seconds. ContextAgora made that possible."
				</p>
			</div>
		</div>

		<!-- Soundmurai spotlight -->
		<div class="border border-accent/20 bg-bg-raised px-6 py-7 sm:px-8 mb-3">
			<!-- Company header -->
			<div class="flex items-center gap-3 mb-5">
				<div class="w-9 h-9 flex items-center justify-center border border-accent/25 bg-accent/10 text-accent text-xs font-semibold shrink-0">
					SM
				</div>
				<div>
					<p class="text-sm font-semibold text-text">Soundmurai</p>
					<p class="text-xs text-text-secondary">Marketplace for live music opportunities</p>
				</div>
			</div>

			<!-- Use case description -->
			<p class="text-sm text-text-secondary leading-relaxed border-l-2 border-accent/30 pl-4 mb-5">
				Soundmurai is building the go-to marketplace for live music. Fully AI-native in their approach, they needed their agents to query live database data — without writing a custom integration for every question.
			</p>

			<!-- Example query -->
			<div class="bg-bg border border-border px-4 py-3 mb-5 text-xs">
				<span class="text-accent font-medium">User asks →</span>
				<span class="text-text italic ml-1">"Which is the average price for independent artists in Berlin?"</span>
			</div>

			<!-- 5-step flow -->
			<ol class="space-y-2.5 mb-6">
				{[
					'The agent finds the right context file for their database',
					'It reads and understands how their DB is structured',
					'It generates a script or request to retrieve artists in Berlin and venue prices',
					'It filters the results that match the question',
					'It delivers a clear, accurate answer to the user',
				].map((step, i) => (
					<li class="flex gap-3 items-start text-sm text-text-secondary">
						<span class="flex-shrink-0 w-5 h-5 border border-accent/30 text-accent text-[10px] font-semibold flex items-center justify-center mt-0.5">
							{i + 1}
						</span>
						<span>{step}</span>
					</li>
				))}
			</ol>

			<!-- Video placeholder -->
			<div class="w-full aspect-video bg-bg border border-dashed border-border flex flex-col items-center justify-center gap-2 text-text-muted">
				<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5 10.5 7.5v9l5.25-3v-3Z"/>
					<path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
				</svg>
				<p class="text-sm text-text-secondary font-medium">Demo video coming soon</p>
				<p class="text-xs">See ContextAgora in action with Soundmurai's live database</p>
			</div>
		</div>

		<!-- MAAT spotlight -->
		<div class="border border-accent/20 bg-bg-raised px-6 py-7 sm:px-8">
			<!-- Company header -->
			<div class="flex items-center gap-3 mb-5">
				<img src="https://www.datocms-assets.com/166339/1754751403-logo.svg" alt="MAAT logo" class="w-9 h-9 shrink-0" />
				<div>
					<p class="text-sm font-semibold text-text">MAAT</p>
					<p class="text-xs text-text-secondary">Gym management for BJJ, MMA & martial arts</p>
				</div>
			</div>

			<!-- Use case description -->
			<p class="text-sm text-text-secondary leading-relaxed border-l-2 border-accent/30 pl-4 mb-5">
				MAAT is building a platform at the intersection of music and arts. With a growing catalogue of events, artists, and venues, they needed their AI to surface meaningful insights from their data without any manual overhead.
			</p>

			<!-- Example query -->
			<div class="bg-bg border border-border px-4 py-3 mb-5 text-xs">
				<span class="text-accent font-medium">User asks →</span>
				<span class="text-text italic ml-1">"Which artists performed at more than three events last month?"</span>
			</div>

			<!-- Steps -->
			<ol class="space-y-2.5 mb-6">
				{[
					'The agent locates the relevant context module for the events catalogue',
					'It reads the schema and understands how artists, events, and venues relate',
					'It generates a query to retrieve artist performance counts for the period',
					'It filters and ranks results by frequency',
					'It returns a clear answer with the matching artists listed',
				].map((step, i) => (
					<li class="flex gap-3 items-start text-sm text-text-secondary">
						<span class="flex-shrink-0 w-5 h-5 border border-accent/30 text-accent text-[10px] font-semibold flex items-center justify-center mt-0.5">
							{i + 1}
						</span>
						<span>{step}</span>
					</li>
				))}
			</ol>

			<!-- Video placeholder -->
			<div class="w-full aspect-video bg-bg border border-dashed border-border flex flex-col items-center justify-center gap-2 text-text-muted">
				<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5 10.5 7.5v9l5.25-3v-3Z"/>
					<path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
				</svg>
				<p class="text-sm text-text-secondary font-medium">Demo video coming soon</p>
				<p class="text-xs">See ContextAgora in action with MAAT's platform</p>
			</div>
		</div>
	</section>

</Base>
