---
import Base from '../layouts/Base.astro';
---

<Base title="ContextAgora: The AI support layer for startups">

	<!-- Hero -->
	<section class="mb-16 sm:mb-24 text-center pt-8 sm:pt-16">
		<h1 class="text-5xl sm:text-7xl font-semibold text-accent tracking-tight mb-4 leading-none">
			ContextAgora
		</h1>
		<p class="text-lg sm:text-xl text-text font-medium mb-6">The AI support layer built for startups</p>
		<p class="text-base text-text-secondary leading-relaxed max-w-sm mx-auto">
			Let your AI agents handle support, ops, and integrations without babysitting every prompt or worrying about leaked credentials.
		</p>
	</section>

	<!-- Waitlist -->
	<section class="mb-16 sm:mb-24">
		<div class="border border-accent/20 bg-bg-raised px-6 py-8 sm:px-8 max-w-lg mx-auto">
			<p class="text-xs font-medium text-accent uppercase tracking-widest mb-3">Early access</p>
			<h2 class="text-lg font-medium text-text mb-1">Built for startups moving fast.</h2>
			<p class="text-sm text-text-secondary mb-6">We're opening up to a small group of early-stage teams first. Join the waitlist and we'll be in touch.</p>
			<form id="waitlist-form" class="flex gap-2">
				<input
					type="email"
					name="email"
					required
					placeholder="your@email.com"
					class="flex-1 bg-bg border border-border text-text text-sm px-3 py-2 outline-none focus:border-accent/50 placeholder:text-text-muted transition-colors"
				/>
				<button
					type="submit"
					id="waitlist-btn"
					class="bg-accent text-bg text-sm font-medium px-4 py-2 hover:bg-accent-hover transition-colors cursor-pointer whitespace-nowrap disabled:opacity-50 disabled:cursor-not-allowed"
				>
					Get early access
				</button>
			</form>
			<p id="waitlist-success" class="hidden text-sm text-text-secondary mt-3">You're on the list. We'll be in touch.</p>
		</div>
	</section>

	<script>
		const LOOPS_FORM_ID = 'cmnwwvqz704ex0i1e6ahjp465';

		const form = document.getElementById('waitlist-form') as HTMLFormElement;
		const btn = document.getElementById('waitlist-btn') as HTMLButtonElement;
		const success = document.getElementById('waitlist-success') as HTMLParagraphElement;

		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			btn.disabled = true;
			btn.textContent = 'Joining...';
			const email = (form.elements.namedItem('email') as HTMLInputElement).value;

			try {
				await fetch(`https://app.loops.so/api/newsletter-form/${LOOPS_FORM_ID}`, {
					method: 'POST',
					headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
					body: new URLSearchParams({ email }),
				});
			} catch {}

			form.classList.add('hidden');
			success.classList.remove('hidden');
		});
	</script>

	<!-- How it works -->
	<section class="mb-16 sm:mb-24">
		<h2 class="text-xs font-medium text-text-muted uppercase tracking-widest mb-10">How it works</h2>
		<dl class="space-y-10">
			<div class="flex gap-5">
				<svg class="w-6 h-6 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9.776c.112-.017.227-.026.344-.026h15.812c.117 0 .232.009.344.026m-16.5 0a2.25 2.25 0 0 0-1.883 2.542l.857 6a2.25 2.25 0 0 0 2.227 1.932H19.05a2.25 2.25 0 0 0 2.227-1.932l.857-6a2.25 2.25 0 0 0-1.883-2.542m-16.5 0V6A2.25 2.25 0 0 1 6 3.75h3.879a1.5 1.5 0 0 1 1.06.44l2.122 2.12a1.5 1.5 0 0 0 1.06.44H18A2.25 2.25 0 0 1 20.25 9v.776" /></svg>
				<div>
					<dt class="text-lg font-semibold text-text mb-1">Direct AI access to all 3rd party tools</dt>
					<dd class="text-sm text-text-secondary leading-relaxed">Add any integration as a module. Your AI agent reads what it needs and acts on it, no custom wiring required.</dd>
				</div>
			</div>
			<div class="flex gap-5">
				<svg class="w-6 h-6 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" /></svg>
				<div>
					<dt class="text-lg font-semibold text-text mb-1">Safe secrets with Infisical and Varlock</dt>
					<dd class="text-sm text-text-secondary leading-relaxed">API keys are resolved at runtime and discarded when the task ends. Never stored, never visible.</dd>
				</div>
			</div>
			<div class="flex gap-5">
				<svg class="w-6 h-6 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m21 7.5-9-5.25L3 7.5m18 0-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" /></svg>
				<div>
					<dt class="text-lg font-semibold text-text mb-1">Up in 30 minutes</dt>
					<dd class="text-sm text-text-secondary leading-relaxed">
						<ol class="list-none space-y-1">
							<li>1. Create a private GitHub repo, this is where your context modules live.</li>
							<li>2. Set up an Infisical project to store your API keys and credentials securely.</li>
							<li>3. Deploy with Docker. That's it.</li>
						</ol>
					</dd>
				</div>
			</div>
			<div class="flex gap-5">
				<svg class="w-6 h-6 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" /></svg>
				<div>
					<dt class="text-lg font-semibold text-text mb-1">Context is the base of AI</dt>
					<dd class="text-sm text-text-secondary leading-relaxed">Modules are the foundation. Every agent action is grounded in the context you've loaded, your docs, your tools, your data.</dd>
				</div>
			</div>
		</dl>
	</section>

</Base>
