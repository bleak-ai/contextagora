@baseUrl = https://eu.infisical.com
@clientId = {{$dotenv INFISICAL_CLIENT_ID}}
@clientSecret = {{$dotenv INFISICAL_CLIENT_SECRET}}
@projectId = {{$dotenv INFISICAL_PROJECT_ID}}
@environment = {{$dotenv INFISICAL_ENVIRONMENT}}

### Step 0: Verify connection
GET {{baseUrl}}/api/status

###

### Step 1: Authenticate (Universal Auth)
# @name login
POST {{baseUrl}}/api/v1/auth/universal-auth/login
Content-Type: application/json

{
  "clientId": "{{clientId}}",
  "clientSecret": "{{clientSecret}}"
}

###

### Step 2: Fetch all secrets
# @ref login
GET {{baseUrl}}/api/v3/secrets/raw?workspaceId={{projectId}}&environment={{environment}}
Authorization: Bearer {{login.accessToken}}

###

### Step 3: Single secret lookup (replace SECRET_NAME)
# @ref login
GET {{baseUrl}}/api/v3/secrets/raw/SECRET_NAME?workspaceId={{projectId}}&environment={{environment}}
Authorization: Bearer {{login.accessToken}}
