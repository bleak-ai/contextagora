# Context Loader — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── GitHub Module Source ──────────────────────────────────────
# The GitHub repo containing your context modules (each module = a folder)
GH_OWNER=
GH_REPO=
GH_TOKEN=

# ── Anthropic (AI) ────────────────────────────────────────────
# Your Anthropic API key (required for the chat feature)
ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_BASE_URL=                          # Optional: custom API endpoint
# ANTHROPIC_DEFAULT_OPUS_MODEL=                # Optional: model override
# ANTHROPIC_DEFAULT_SONNET_MODEL=              # Optional: model override
# ANTHROPIC_DEFAULT_HAIKU_MODEL=               # Optional: model override

# ── Infisical (Secret Management) ─────────────────────────────
# Only needed if your modules use secrets resolved via Varlock + Infisical.
# Leave commented out if your modules don't need secrets.
# INFISICAL_CLIENT_ID=
# INFISICAL_CLIENT_SECRET=
# INFISICAL_PROJECT_ID=
# INFISICAL_ENVIRONMENT=dev
# INFISICAL_SITE_URL=https://app.infisical.com
